  "paths": {
    "/login": {
      "post": {
        "summary": "Log in a user",
        "deprecated": false,
        "description": "Log in to get a generated JWT.",
        "tags": [
          "auth"
        ],
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": {
                    "type": "string",
                    "minLength": 3,
                    "maxLength": 255
                  },
                  "password": {
                    "type": "string",
                    "minLength": 8
                  }
                },
                "required": [
                  "username",
                  "password"
                ]
              },
              "example": {
                "username": "en999zz",
                "password": "M1IKDd68aZje6SJ"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "integer",
                      "description": "HTTP status code",
                      "default": 200,
                      "minimum": 0,
                      "maximum": 999
                    },
                    "access_token": {
                      "type": "string",
                      "description": "JWT"
                    }
                  },
                  "required": [
                    "status",
                    "access_token"
                  ]
                },
                "example": {
                  "status": 200,
                  "access_token": "eyJhbGciOiJSUzI1NiIsInR5cCI6IkpXVCJ9.ey..."
                }
              }
            },
            "headers": {}
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized",
            "description": ""
          },
          "500": {
            "$ref": "#/components/responses/Internal Server Error",
            "description": ""
          }
        },
        "security": []
      }
    },
    "/register": {
      "post": {
        "summary": "Register a new account",
        "deprecated": false,
        "description": "Register a new account.",
        "tags": [
          "auth"
        ],
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": {
                    "type": "string",
                    "minLength": 3,
                    "maxLength": 255
                  },
                  "email": {
                    "type": "string"
                  },
                  "password": {
                    "type": "string",
                    "minLength": 8
                  }
                },
                "required": [
                  "username",
                  "email",
                  "password"
                ]
              },
              "example": {
                "username": "en999zz",
                "email": "en999zz2@student.lnu.se",
                "password": "M1IKDd68aZje6SJ"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "integer",
                      "description": "HTTP status code",
                      "title": ""
                    },
                    "id": {
                      "type": "integer",
                      "description": "The ID of the resource",
                      "minimum": 0
                    },
                    "username": {
                      "type": "string",
                      "description": "The user's username."
                    },
                    "email": {
                      "type": "string",
                      "description": "The user's email address."
                    }
                  },
                  "required": [
                    "status",
                    "username",
                    "email",
                    "id"
                  ]
                },
                "example": {
                  "status": 201,
                  "id": 3,
                  "username": "en999zz",
                  "email": "en999zz2@student.lnu.se"
                }
              }
            },
            "headers": {}
          },
          "400": {
            "$ref": "#/components/responses/Bad Request",
            "description": ""
          },
          "500": {
            "$ref": "#/components/responses/Internal Server Error",
            "description": ""
          }
        },
        "security": []
      }
    },
    "/users/{id}": {
      "delete": {
        "summary": "Delete a user",
        "deprecated": false,
        "description": "Delete a user by ID. Requires authentication.",
        "tags": [
          "users"
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "The ID of the user.",
            "required": true,
            "schema": {
              "type": "integer",
              "description": "The ID of the user",
              "minimum": 1
            }
          }
        ],
        "responses": {
          "204": {
            "description": "The server successfully processed the request and is not returning any content.",
            "headers": {}
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized",
            "description": ""
          },
          "404": {
            "$ref": "#/components/responses/Not Found",
            "description": ""
          },
          "500": {
            "$ref": "#/components/responses/Internal Server Error",
            "description": ""
          }
        },
        "security": [
          {
            "bearer": []
          }
        ]
      }
    }
  },
