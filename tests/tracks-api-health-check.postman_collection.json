            {
              "name": "Register a new account (Register (success))",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "const responseJson = pm.response.json();\r",
                      "const requestBody = pm.request.body.toJSON();\r",
                      "const variables = JSON.parse(requestBody.raw);\r",
                      "\r",
                      "pm.collectionVariables.set('password', variables.password);\r",
                      "const correctStatusCode = 201\r",
                      "\r",
                      "pm.test(`Status code is ${correctStatusCode}`, () => {\r",
                      "  pm.response.to.have.status(correctStatusCode);\r",
                      "});\r",
                      "\r",
                      "pm.test('Response has expected properties', () => {\r",
                      "    pm.expect(responseJson).to.have.all.keys('email', 'username', 'id', 'status');\r",
                      "})\r",
                      "\r",
                      "pm.test('id is a number', () => {\r",
                      "    pm.expect(responseJson.id).to.be.a('number');\r",
                      "})\r",
                      "\r",
                      "pm.test('Password is not returned', () => {\r",
                      "    pm.expect(responseJson).to.not.have.any.keys('password');\r",
                      "})\r",
                      "\r",
                      "// Set variables\r",
                      "pm.collectionVariables.set('username', responseJson.username);\r",
                      "pm.collectionVariables.set('user_id', responseJson.id);\r",
                      "\r",
                      "pm.execution.setNextRequest(\"Log in a user (Login (success))\");\r",
                      ""
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                }
              ],
              "protocolProfileBehavior": {
                "disabledSystemHeaders": {
                  "content-type": true
                }
              },
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json",
                    "type": "text"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\r\n    \"username\": \"{{$randomUserName}}\",\r\n    \"password\": \"{{$randomPassword}}\",\r\n    \"email\": \"{{$randomEmail}}\"\r\n}\r\n"
                },
                "url": {
                  "raw": "{{auth_url}}/register",
                  "host": [
                    "{{auth_url}}"
                  ],
                  "path": [
                    "register"
                  ]
                }
              },
              "response": []
            },
            {
              "name": "Log in a user (Login (success))",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "const responseJson = pm.response.json();\r",
                      "\r",
                      "const correctStatusCode = 200\r",
                      "\r",
                      "pm.test(`Status code is ${correctStatusCode}`, () => {\r",
                      "  pm.response.to.have.status(correctStatusCode);\r",
                      "});\r",
                      "\r",
                      "pm.test('Response has expected properties', () => {\r",
                      "    pm.expect(responseJson).to.have.all.keys('status', 'access_token');\r",
                      "})\r",
                      "\r",
                      "pm.test('A token is returned', () => {\r",
                      "    pm.expect(responseJson.access_token).to.not.be.undefined;\r",
                      "})\r",
                      "\r",
                      "// Set variables\r",
                      "pm.collectionVariables.set('access_token', responseJson.access_token);\r",
                      "\r",
                      "pm.execution.setNextRequest(\"Auth test (success)\");\r",
                      ""
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                }
              ],
              "protocolProfileBehavior": {
                "disabledSystemHeaders": {
                  "content-type": true
                }
              },
              "request": {
                "method": "POST",
                "header": [
                  {
                    "key": "Content-Type",
                    "value": "application/json",
                    "type": "text"
                  }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\r\n    \"username\": \"{{username}}\",\r\n    \"password\": \"{{password}}\"\r\n}\r\n"
                },
                "url": {
                  "raw": "{{auth_url}}/login",
                  "host": [
                    "{{auth_url}}"
                  ],
                  "path": [
                    "login"
                  ]
                }
              },
              "response": []
            },
            {
              "name": "Delete a user (Delete user (success))",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "const correctStatusCode = 204\r",
                      "\r",
                      "pm.test(`Status code is ${correctStatusCode}`, () => {\r",
                      "  pm.response.to.have.status(correctStatusCode);\r",
                      "});\r",
                      "\r",
                      "pm.execution.setNextRequest(null);\r",
                      ""
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                }
              ],
              "request": {
                "auth": {
                  "type": "bearer",
                  "bearer": [
                    {
                      "key": "token",
                      "value": "{{access_token}}",
                      "type": "string"
                    }
                  ]
                },
                "method": "DELETE",
                "header": [],
                "url": {
                  "raw": "{{auth_url}}/users/:id",
                  "host": [
