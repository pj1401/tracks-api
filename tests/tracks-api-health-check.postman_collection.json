          "name": "Auth API v1",
          "item": [
            {
              "name": "Auth v1 health check",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "const responseJson = pm.response.json();\r",
                      "\r",
                      "const correctStatusCode = 200\r",
                      "const correctMessage = \"OK\"\r",
                      "\r",
                      "pm.test(`Status code is ${correctStatusCode}`, () => {\r",
                      "  pm.response.to.have.status(correctStatusCode);\r",
                      "});\r",
                      "\r",
                      "pm.test('Response has expected properties', () => {\r",
                      "    pm.expect(responseJson).to.have.all.keys('status', 'message');\r",
                      "})\r",
                      "\r",
                      "pm.test(`Message is: ${correctMessage}`, () => {\r",
                      "  pm.expect(responseJson.message).to.equal(correctMessage);\r",
                      "});\r",
                      "\r",
                      "pm.execution.setNextRequest(\"Auth v1 docs\");\r",
                      ""
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                }
