                    {
                      "name": "Register a new account (Register (success))",
                      "event": [
                        {
                          "listen": "test",
                          "script": {
                            "exec": [
                              "const responseJson = pm.response.json();\r",
                              "const requestBody = pm.request.body.toJSON();\r",
                              "const variables = JSON.parse(requestBody.raw);\r",
                              "\r",
                              "pm.collectionVariables.set('password', variables.password);\r",
                              "const correctStatusCode = 201\r",
                              "\r",
                              "pm.test(`Status code is ${correctStatusCode}`, () => {\r",
                              "  pm.response.to.have.status(correctStatusCode);\r",
                              "});\r",
                              "\r",
                              "pm.test('Response has expected properties', () => {\r",
                              "    pm.expect(responseJson).to.have.all.keys('email', 'username', 'id', 'status');\r",
                              "})\r",
                              "\r",
                              "pm.test('id is a number', () => {\r",
                              "    pm.expect(responseJson.id).to.be.a('number');\r",
                              "})\r",
                              "\r",
                              "pm.test('Password is not returned', () => {\r",
                              "    pm.expect(responseJson).to.not.have.any.keys('password');\r",
                              "})\r",
                              "\r",
                              "// Set variables\r",
                              "pm.collectionVariables.set('username', responseJson.username);\r",
                              "pm.collectionVariables.set('user_id', responseJson.id);\r",
                              "\r",
                              "pm.execution.setNextRequest(\"Register duplicate (failure)\");\r",
                              ""
                            ],
                            "type": "text/javascript",
                            "packages": {},
                            "requests": {}
                          }
                        }
